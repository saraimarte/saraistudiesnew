---
import Main from '@layouts/MainLayout.astro';
const pathHome = './';

const folderPath1 = "../../toolbox";
const folderPath2 = "../../rankings";
const folderPath3 = "../../ratings";
const folderPath4 = "../../graduation";

---

<Main  folderPath1= {folderPath1} folderPath2 = {folderPath2} folderPath3 = {folderPath3} folderPath4 = {folderPath4} pathHome = {pathHome} >

<h3>ChatGPT Alternatives</h3>

<br>

<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Tool Name</th>
        <th>Category</th>
        <th>Link</th>
      </tr>
    </thead>
    <tbody>
      <tr><td>ChatGPT</td><td>General AI</td><td><a href="https://chatgpt.com/" target="_blank">chatgpt.com</a></td></tr>
      <tr><td>Claude.ai</td><td>General AI</td><td><a href="https://claude.ai/chats" target="_blank">claude.ai</a></td></tr>
      <tr><td>Microsoft Copilot</td><td>General AI</td><td><a href="https://copilot.microsoft.com/" target="_blank">copilot.microsoft.com</a></td></tr>
      <tr><td>Gemini AI</td><td>General AI</td><td><a href="https://gemini.google.com/app" target="_blank">gemini.google.com</a></td></tr>
      <tr><td>NotebookLM</td><td>Study Assistant</td><td><a href="https://notebooklm.google/" target="_blank">notebooklm.google</a></td></tr>
      <tr><td>Studyx</td><td>Study Assistant</td><td><a href="https://studyx.ai/webapp/home" target="_blank">studyx.ai</a></td></tr>
      <tr><td>Pi</td><td>Personal AI</td><td><a href="https://pi.ai/talk" target="_blank">pi.ai</a></td></tr>
      <tr><td>QuestionAI</td><td>Homework Help</td><td><a href="https://www.questionai.com/" target="_blank">questionai.com</a></td></tr>
      <tr><td>Exa.ai</td><td>Search Engine</td><td><a href="https://exa.ai/" target="_blank">exa.ai</a></td></tr>
      <tr><td>Perplexity AI</td><td>Search Engine</td><td><a href="https://www.perplexity.ai/" target="_blank">perplexity.ai</a></td></tr>
      <tr><td>You.com</td><td>Search Engine</td><td><a href="https://you.com/" target="_blank">you.com</a></td></tr>
    </tbody>
  </table>
</div>


<br/>

<h2 class="title"> Rutgers CS Students </h2>
<div class="table-wrapper">
  <table>
    <tbody>
      <tr>
        <td style="font-weight: bold;">Request SPN for CS</td>
        <td><a href="https://secure.sas.rutgers.edu/apps/special_permission/cs/" target="_blank">Rutgers SPN Portal</a></td>
      </tr>
    </tbody>
  </table>
</div>

</Main>

<style>
    .title {
        font-weight: 600;
        font-size: 1.5em;
        margin: 20px 0 10px 0;
    }

    .table-wrapper {
        width: 100%;
        margin-bottom: 25px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background-color: #f4f7f9;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-family: sans-serif;
        color: #333;
        /* Standard table behavior - grows/shrinks with content */
        table-layout: auto; 
    }

    th {
        background-color: #edf2f7;
        padding: 12px;
        border-bottom: 2px solid #cbd5e1;
        text-align: left;
    }

    td {
        padding: 12px;
        border-bottom: 1px solid #e2e8f0;
        /* This ensures text wraps instead of pushing the table off-screen */
        word-break: break-word; 
    }

    tr:last-child td {
        border-bottom: none;
    }

    a {
        color: #2563eb;
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
    }
    h3{
        margin:10px 0 10px 0;

    }
</style>