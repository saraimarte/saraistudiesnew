export async function getStaticPaths() {
  const collectionNames = ['calc2', 'macc', 'statMethods', 'supplyChain', 'writingForMedia', 'fmanage','mis', 'dataStructures', 'linearAlg', 'discreteStructures1', 'discreteStructures2', 'operationsManagement', 'computerArchitecture', 'investmentAnalysis', 'ai', 'cs336', 'softwareMethodology','cs344', 'investmentBankingAnalysis', 'derivatives', 'treasuryManagement', 'advancedCorporateFinance', 'internationalFinancialManagement', 'businessEthics', 'dataScience', 'internetTechnology']; 

  return collectionNames.map(name => ({
    params: { slug: name },
  }));
